# CricketIQ Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# CricketData.org API key
# Get yours at: https://cricketdata.org
CRICKET_API_KEY=your-api-key-here

# Local PostgreSQL connection string
# Default for local Postgres (no password):
DATABASE_URL=postgresql://localhost:5432/cricketiq

# Anthropic API key (needed in Week 4 for AI reports)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your-key-here
